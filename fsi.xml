<?xml version="1.0" encoding="UTF-8"?>
<febio_spec version="4.0">
  <Module type="fluid"/>
  <Module type="FSI"/>
  
  <Control>
    <title>Cardiac FSI Simulation - Left Ventricle</title>
    <time_steps>100</time_steps>
    <step_size>0.01</step_size>
    <solver>
      <max_refs>15</max_refs>
      <max_ups>10</max_ups>
      <diverge_reform>1</diverge_reform>
      <reform_each_time_step>1</reform_each_time_step>
      <dtol>0.001</dtol>
      <etol>0.01</etol>
      <rtol>0.001</rtol>
      <lstol>0.9</lstol>
      <min_residual>1e-20</min_residual>
    </solver>
    <time_stepper>
      <dtmin>0.001</dtmin>
      <dtmax>0.05</dtmax>
      <max_retries>5</max_retries>
      <opt_iter>10</opt_iter>
    </time_stepper>
    <analysis type="dynamic"/>
    <plot_level>PLOT_MAJOR_ITRS</plot_level>
    <output>
      <plotfile type="febio">
        <var type="displacement"/>
        <var type="stress"/>
        <var type="fluid pressure"/>
        <var type="fluid velocity"/>
        <var type="relative volume"/>
      </plotfile>
    </output>
  </Control>

  <Globals>
    <Constants>
      <T>0</T>
      <R>0</R>
      <Fc>0</Fc>
    </Constants>
  </Globals>

  <Material>
    <!-- Myocardium material (solid) -->
    <material id="1" name="myocardium" type="orthotropic elastic">
      <density>1.0</density>
      <elastic>
        <E1>100</E1>
        <E2>100</E2>
        <E3>50</E3>
        <v12>0.4</v12>
        <v23>0.4</v23>
        <v31>0.4</v31>
        <G12>30</G12>
        <G23>30</G23>
        <G31>30</G31>
      </elastic>
    </material>
    
    <!-- Active contraction material for cardiac muscle -->
    <material id="2" name="active_contraction" type="active contraction">
      <activation>0.1</activation>
      <max_tension>100</max_tension>
      <T0>0.2</T0>
      <Tmax>0.5</Tmax>
    </material>
    
    <!-- Blood material (fluid) -->
    <material id="3" name="blood" type="Newtonian fluid">
      <density>1.06</density>
      <viscosity>0.04</viscosity>
    </material>
    
    <!-- FSI interface material -->
    <material id="4" name="FSI_interface" type="rigid body">
      <density>0</density>
    </material>
  </Material>

  <Geometry>
    <!-- Define a simple ellipsoid ventricle geometry -->
    <Nodes>
      <!-- Base nodes (z=0 plane) -->
      <node id="1"> 0.0, 0.0, 0.0</node>
      <node id="2"> 3.0, 0.0, 0.0</node>
      <node id="3"> 0.0, 2.0, 0.0</node>
      <node id="4">-3.0, 0.0, 0.0</node>
      <node id="5"> 0.0,-2.0, 0.0</node>
      
      <!-- Apex nodes (z=5 plane) -->
      <node id="6"> 0.0, 0.0, 5.0</node>
      <node id="7"> 2.0, 0.0, 5.0</node>
      <node id="8"> 0.0, 1.5, 5.0</node>
      <node id="9">-2.0, 0.0, 5.0</node>
      <node id="10">0.0,-1.5, 5.0</node>
      
      <!-- Additional nodes for better resolution -->
      <node id="11"> 2.5, 0.0, 2.5</node>
      <node id="12"> 0.0, 1.8, 2.5</node>
      <node id="13">-2.5, 0.0, 2.5</node>
      <node id="14"> 0.0,-1.8, 2.5</node>
    </Nodes>

    <Elements>
      <!-- Solid elements for myocardium -->
      <solid mat="1" el_type="penta6">
        <elem id="1">1,2,3,6,7,8</elem>
        <elem id="2">1,3,4,6,8,9</elem>
        <elem id="3">1,4,5,6,9,10</elem>
        <elem id="4">1,5,2,6,10,7</elem>
      </solid>
      
      <!-- Fluid elements for blood pool -->
      <fluid mat="3" el_type="penta6">
        <elem id="5">2,7,11,3,8,12</elem>
        <elem id="6">3,8,12,4,9,13</elem>
        <elem id="7">4,9,13,5,10,14</elem>
        <elem id="8">5,10,14,2,7,11</elem>
      </fluid>
    </Elements>

    <Surface>
      <!-- Endocardial surface (fluid-structure interface) -->
      <Surface name="endocardium" type="element">
        <elem_surface>5,0</elem_surface>
        <elem_surface>6,0</elem_surface>
        <elem_surface>7,0</elem_surface>
        <elem_surface>8,0</elem_surface>
      </Surface>
      
      <!-- Epicardial surface -->
      <Surface name="epicardium" type="element">
        <elem_surface>1,3</elem_surface>
        <elem_surface>2,3</elem_surface>
        <elem_surface>3,3</elem_surface>
        <elem_surface>4,3</elem_surface>
      </Surface>
      
      <!-- Base surface -->
      <Surface name="base" type="element">
        <elem_surface>1,0</elem_surface>
        <elem_surface>2,0</elem_surface>
        <elem_surface>3,0</elem_surface>
        <elem_surface>4,0</elem_surface>
      </Surface>
      
      <!-- Apex surface -->
      <Surface name="apex" type="element">
        <elem_surface>1,4</elem_surface>
        <elem_surface>2,4</elem_surface>
        <elem_surface>3,4</elem_surface>
        <elem_surface>4,4</elem_surface>
      </Surface>
    </Surface>
  </Geometry>

  <Boundary>
    <!-- Fix base nodes -->
    <fix dof="x y z" node_set="base">1,2,3,4,5</fix>
    
    <!-- Pressure boundary conditions -->
    <pressure type="fluid" surface="endocardium">
      <scale lc="1">10.0</scale>
    </pressure>
    
    <!-- Active contraction on myocardium -->
    <active_contraction material="2" domain="solid:1,2,3,4">
      <activation lc="2">1.0</activation>
    </active_contraction>
  </Boundary>

  <Loads>
    <!-- Time-varying pressure load (simulating cardiac cycle) -->
    <loadcurve id="1" type="linear">
      <point>0,0</point>
      <point>0.2,8</point>
      <point>0.5,12</point>
      <point>0.8,6</point>
      <point>1.0,2</point>
    </loadcurve>
    
    <!-- Activation curve for cardiac contraction -->
    <loadcurve id="2" type="linear">
      <point>0,0</point>
      <point>0.1,0</point>
      <point>0.3,1</point>
      <point>0.6,0.8</point>
      <point>0.9,0</point>
      <point>1.0,0</point>
    </loadcurve>
  </Loads>

  <Contact>
    <!-- FSI interface between blood and myocardium -->
    <fsi type="fluid-solid" surface_pair="endocardium">
      <tolerance>0.01</tolerance>
      <penalty>1000</penalty>
      <auto_penalty>1</auto_penalty>
      <two_pass>1</two_pass>
      <search_tolerance>0.1</search_tolerance>
    </fsi>
  </Contact>

  <Output>
    <logfile>
      <node_data data="displacement"/>
      <node_data data="velocity"/>
      <element_data data="stress" mat="1"/>
      <element_data data="fluid pressure" mat="3"/>
      <element_data data="fluid velocity" mat="3"/>
      <surface_data data="relative volume" surface="endocardium"/>
    </logfile>
  </Output>

  <Step name="step1">
    <Analysis type="dynamic"/>
    <time_steps>50</time_steps>
    <step_size>0.02</step_size>
    
    <Boundary>
      <fix dof="x y z" node_set="base">1,2,3,4,5</fix>
    </Boundary>
    
    <Loads>
      <pressure type="fluid" surface="endocardium">
        <scale lc="1">10.0</scale>
      </pressure>
    </Loads>
    
    <Contact>
      <fsi type="fluid-solid" surface_pair="endocardium"/>
    </Contact>
    
    <Output>
      <plotfile type="febio">
        <var type="displacement"/>
        <var type="stress"/>
        <var type="fluid pressure"/>
        <var type="fluid velocity"/>
        <var type="relative volume"/>
      </plotfile>
    </Output>
  </Step>

</febio_spec>