# Example environment variables for running locally (copy to .env)
# NOTE: Do NOT commit your real secrets.

# Fitbit / OAuth (if using Fitbit integration)
FITBIT_CLIENT_ID=your_id_here
FITBIT_CLIENT_SECRET=your_secret_here
FITBIT_REDIRECT_URI=http://localhost:8000/auth/fitbit/callback

# Optional: override the port when running locally (default is 8000)
PORT=8000
